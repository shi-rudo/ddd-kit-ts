{
	"name": "@shirudo/ddd-kit",
	"version": "3.0.0-rc.1",
	"description": "Composable TypeScript toolkit for tactical DDD",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/shi-rudo/ddd-kit-ts.git"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./utils": {
			"types": "./dist/utils.d.ts",
			"import": "./dist/utils.js"
		},
		"./http": {
			"types": "./dist/http.d.ts",
			"import": "./dist/http.js"
		},
		"./money": {
			"types": "./dist/money.d.ts",
			"import": "./dist/money.js"
		},
		"./presentation": {
			"types": "./dist/presentation.d.ts",
			"import": "./dist/presentation.js"
		},
		"./testing": {
			"types": "./dist/testing.d.ts",
			"import": "./dist/testing.js"
		}
	},
	"engines": {
		"node": ">=22"
	},
	"sideEffects": false,
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"test": "vitest",
		"clean": "rm -rf dist",
		"lint": "biome lint .",
		"format": "pnpm exec biome format --write . && pnpm exec biome lint --write . && pnpm exec biome check --write .",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "npm run clean && vitest run && npm run build",
		"docs:api": "typedoc",
		"docs:dev": "typedoc && vitepress dev docs",
		"docs:build": "typedoc && vitepress build docs",
		"docs:preview": "vitepress preview docs",
		"mutate:money": "stryker run stryker.money.json"
	},
	"keywords": [
		"ddd",
		"domain",
		"typescript",
		"toolkit"
	],
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@biomejs/biome": "2.1.4",
		"@shirudo/base-error": "^8.1.0",
		"@shirudo/result": "^1.0.0",
		"@stryker-mutator/core": "^9.6.1",
		"@stryker-mutator/vitest-runner": "^9.6.1",
		"fast-check": "^4.9.0",
		"tsup": "^8.5.0",
		"typedoc": "^0.28.19",
		"typedoc-plugin-markdown": "^4.11.0",
		"typedoc-vitepress-theme": "^1.1.2",
		"typescript": "^5.9.2",
		"vitepress": "^1.6.4",
		"vitepress-plugin-llms": "^1.13.0",
		"vitest": "^3.2.6"
	},
	"private": false,
	"author": "Shirudo",
	"contributors": [
		"Shirudo"
	],
	"homepage": "https://github.com/shi-rudo/ddd-kit-ts#readme",
	"bugs": {
		"url": "https://github.com/shi-rudo/ddd-kit-ts/issues"
	},
	"peerDependencies": {
		"@shirudo/base-error": "^8.0.0",
		"@shirudo/result": "^1.0.0"
	}
}
