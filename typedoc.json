{
	"$schema": "https://typedoc.org/schema.json",
	"entryPoints": ["src/index.ts"],
	"out": "docs/api",
	"plugin": ["typedoc-plugin-markdown", "typedoc-vitepress-theme"],
	"readme": "none",
	"useCodeBlocks": true,
	"expandObjects": true,
	"sort": ["source-order"],
	"excludeInternal": true,
	"docsRoot": "docs",
	"sidebar": {
		"autoConfiguration": true,
		"format": "vitepress",
		"pretty": true,
		"collapsed": false
	}
}
